flowchart TD
%% ----------------- STYLE DEFINITIONS -----------------
classDef sensors fill:#cce5ff,stroke:#3399ff,stroke-width:1px,color:#000;
classDef perception fill:#d4edda,stroke:#28a745,stroke-width:1px,color:#000;
classDef safety fill:#fff3cd,stroke:#ffc107,stroke-width:1px,color:#000;
classDef nav2 fill:#e2d9f3,stroke:#6f42c1,stroke-width:1px,color:#000;
classDef mapping fill:#f8d7da,stroke:#dc3545,stroke-width:1px,color:#000;
classDef hardware fill:#d1ecf1,stroke:#17a2b8,stroke-width:1px,color:#000;
classDef tf fill:#f0f0f0,stroke:#6c757d,stroke-width:1px,color:#000;
classDef vslam fill:#dcd3f7,stroke:#6f42c1,stroke-width:1px,color:#000;
classDef teleop fill:#fff3cd,stroke:#ffc107,stroke-width:1px,color:#000;
classDef startup fill:#cce5ff,stroke:#3399ff,stroke-width:1px,color:#000;
classDef fileops fill:#cce5ff,stroke:#3399ff,stroke-width:1px,color:#000;

%% ----------------- STARTUP -----------------
StartNav["bluebot start-nav <map_yaml>"]:::startup
StartMap["bluebot start-map"]:::startup
Stack["start_stack()"]:::startup

%% ----------------- SENSORS -----------------
Depth["Depth Camera\n(aligned_depth_to_color/image_raw)"]:::sensors
VslamOdom["VSLAM Odometry\n(/visual_slam/tracking/odometry)"]:::sensors
Scan["Lidar Scan\n(/scan)"]:::sensors
IMU["IMU\n(/imu/data)"]:::sensors
RealSense["RealSense Camera"]:::sensors

%% ----------------- PERCEPTION -----------------
DropDetector["Drop Detector Node"]:::perception
DropTopic["/drop_detected"]:::perception

%% ----------------- SAFETY & MOTION -----------------
CmdIn["/cmd_vel"]:::safety
Gate["Cmd_vel Safety Gate"]:::safety
CmdSafe["/cmd_vel_safe"]:::safety
SerialBridge["ros2_serial_diff_drive_bridge"]:::hardware
Motors["Motor Controller"]:::hardware

%% ----------------- VSLAM -----------------
VSLAM["Isaac ROS Visual SLAM\n(direct or NITROS)"]:::vslam

%% ----------------- NAV2 -----------------
Nav2Stack["nav2_bringup\n(planner + controller + BT + costmaps)"]:::nav2
AMCL["AMCL\nodom_topic=/odom"]:::nav2
Planner["Planner"]:::nav2
Controller["Controller"]:::nav2
BT["Behavior Tree"]:::nav2
LocalCM["Local Costmap + Nvblox layer"]:::mapping
MapTopic["/map"]:::mapping
TFmap["/tf map->odom"]:::tf
InitialPose["/initialpose"]:::tf

%% ----------------- STATE -----------------
EKF["State Estimation\n(robot_localization EKF)"]:::hardware
FusedOdom["Fused odometry\n(/odometry/filtered -> /odom)"]:::hardware
RSP["robot_state_publisher"]:::hardware

%% ----------------- TELEOP & BRIDGE -----------------
Teleop["teleop_twist_joy\n(/joy -> /cmd_vel)"]:::teleop
Foxglove["Foxglove Bridge :8765"]:::teleop
Waypoints["/foxglove/waypoints"]:::teleop
WPBridge["foxglove_waypoint_bridge"]:::teleop
NavThroughPoses["/navigate_through_poses action"]:::teleop
Status["/foxglove/waypoints/status"]:::teleop

%% ----------------- MAPPING -----------------
SLAMTB["SLAM Toolbox / slam_toolbox"]:::mapping
Nvblox["Nvblox Node"]:::mapping
MappingJob["mapping_job.launch.py\n(slam:=False)"]:::mapping
MapFiles["/ssd/maps/<name>.yaml + .pgm"]:::fileops
WaypointsYAML["/ssd/maps/waypoints.yaml"]:::fileops
CaptureWP["bluebot.sh capture-waypoint"]:::teleop
SendWP["bluebot.sh send-waypoints"]:::teleop
SaveMap["bluebot.sh save-map"]:::teleop

%% ----------------- DATA FLOW -----------------

%% --- Startup ---
StartNav --> Stack
StartMap --> Stack

%% --- Hardware & Sensors ---
Stack --> Depth
Stack --> VslamOdom
Stack --> Scan
Stack --> IMU
Stack --> RealSense
Stack --> SerialBridge
Stack --> Motors
Stack --> RSP
Stack --> Teleop
Stack --> Foxglove
Stack --> EKF

%% --- State Estimation ---
EKF --> FusedOdom
FusedOdom --> Nav2Stack

%% --- Safety & Motion ---
CmdIn --> Gate
DropTopic --> Gate
Gate --> CmdSafe
CmdSafe --> SerialBridge

%% --- VSLAM & Perception ---
Depth --> DropDetector
VslamOdom --> DropDetector
DropDetector --> DropTopic
RealSense --> VSLAM
IMU --> VSLAM
VSLAM --> VslamOdom

%% --- SLAM / Mapping ---
Scan --> SLAMTB
SLAMTB --> MapTopic
SLAMTB --> TFmap
Depth --> Nvblox
Nvblox --> LocalCM

%% --- Nav2 ---
Nav2Stack --> Planner
Nav2Stack --> Controller
Nav2Stack --> BT
Planner --> Controller
Controller --> CmdSafe
BT --> Planner
BT --> Controller
MapTopic --> Nav2Stack
TFmap --> Nav2Stack
LocalCM --> Nav2Stack
InitialPose --> Nav2Stack

%% --- AMCL ---
AMCL --> Nav2Stack
FusedOdom --> AMCL

%% --- Waypoints / Foxglove ---
Waypoints --> WPBridge --> NavThroughPoses --> Nav2Stack
WPBridge --> Status

%% --- Waypoint Capture & Map Save ---
TFmap --> CaptureWP --> WaypointsYAML
WaypointsYAML --> SendWP --> Waypoints
MapTopic --> SaveMap --> MapFiles
