flowchart TD
  A["bluebot start-nav <map_yaml>"] --> B["start_stack()"]
  B --> C["ros2_serial_diff_drive_bridge\nodom_topic=/odom_raw, publish_tf=false"]
  B --> D["serial_diff_drive_hw bringup\ncontroller_manager + controllers"]
  B --> E["robot_state_publisher"]
  B --> F["Lidar + static tf\n/frame_id=laser, /scan"]
  B --> G["IMU node\n/imu/data_raw, /imu/orientation"]
  B --> H["RealSense camera"]
  B --> I["Isaac ROS Visual SLAM\n(direct or NITROS)"]
  B --> J["teleop_twist_joy\n/joy -> /cmd_vel"]
  B --> K["Foxglove Bridge"]
  B --> L["State Estimation\nrobot_localization EKF"]
  L --> |"/odometry/filtered -> /odom"| N["Fused odom for Nav2"]

  B --> O["nav2_bringup bringup_launch.py\nslam:=False, map=<map_yaml>"]
  O --> P["localization_launch.py\n(amcl)"]
  P --> Q["AMCL\na. odom_topic=/odom"]
  O --> R["navigation_launch.py"]
  R --> S["controller_server\nplanner_server\nbt_navigator\ncostmaps"]

  B --> T["optional: isaac grid localization bridge\n-> /initialpose"]
