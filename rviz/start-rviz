#!/bin/bash

source /opt/ros/humble/setup.bash
source /ssd/ros2_ws/install/setup.bash

selected_config="${1:-nav}"

case "$selected_config" in
  nav)
    rviz_config="/ssd/ros2_ws/rviz/my_house_nav.rviz"
    ;;
  map-explore)
    rviz_config="/ssd/ros2_ws/rviz/my_house_map_explore.rviz"
    ;;
  *)
    rviz_config="$selected_config"
    ;;
esac

if [[ ! -f "$rviz_config" ]]; then
  echo "Usage: $0 [nav|map-explore|path_to_config]"
  echo "  nav (default): use /ssd/ros2_ws/rviz/my_house_nav.rviz"
  echo "  map-explore:   use /ssd/ros2_ws/rviz/my_house_map_explore.rviz"
  exit 1
fi

rviz2 -d "$rviz_config"
